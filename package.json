{
  "name": "vscode-git-constellation",
  "displayName": "GitConstellation",
  "description": "JetBrains-style Git visualization for VS Code",
  "version": "1.0.2",
  "publisher": "flybugxyz",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/flybugxyz/vscode-git-constellation.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "git-constellation.testOpenAISettings",
        "title": "Test OpenAI Settings"
      },
      {
        "command": "git-constellation.viewFileHistory",
        "title": "View File History (GitConstellation)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "git-constellation.viewFileHistory",
          "when": "resourceScheme == file",
          "group": "git-constellation"
        }
      ],
      "editor/context": [
        {
          "command": "git-constellation.viewFileHistory",
          "when": "resourceScheme == file",
          "group": "git-constellation"
        }
      ]
    },
    "configuration": {
      "title": "GitConstellation",
      "properties": {
        "git-constellation.openai.apiUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1/chat/completions",
          "markdownDescription": "OpenAI API URL. [Test Configuration](command:git-constellation.testOpenAISettings)"
        },
        "git-constellation.openai.apiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI API Key."
        },
        "git-constellation.openai.model": {
          "type": "string",
          "default": "gpt-3.5-turbo",
          "description": "OpenAI Model."
        },
        "git-constellation.openai.prompt": {
          "type": "string",
          "default": "Generate a concise, conventional commit message based on the following git diff. Output ONLY the commit message without any markdown code blocks or quotes.",
          "description": "System prompt for generating commit messages."
        },
        "git-constellation.maxCommits": {
          "type": "number",
          "default": 1000,
          "description": "Maximum number of commits to display in the log. Set to 0 for unlimited (not recommended for large repositories)."
        }
      }
    },
    "viewsContainers": {
      "panel": [
        {
          "id": "git-constellation",
          "title": "GitConstellation",
          "icon": "$(git-branch)"
        }
      ]
    },
    "views": {
      "git-constellation": [
        {
          "type": "webview",
          "id": "git-constellation.log",
          "name": "Log"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run build-webview && webpack",
    "watch": "webpack --watch",
    "package": "npm run build-webview && webpack --mode production --devtool hidden-source-map",
    "build-webview": "vite build",
    "watch-webview": "vite build --watch",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.80.0",
    "@vitejs/plugin-react": "^6.0.2",
    "ts-loader": "^9.4.4",
    "typescript": "^5.1.6",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "simple-git": "^3.36.0"
  }
}