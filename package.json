{
  "name": "vscode-git-jb",
  "displayName": "Git JB Style",
  "description": "JetBrains-style Git visualization for VS Code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "git-jb",
          "title": "Git JB Style",
          "icon": "$(git-branch)"
        }
      ]
    },
    "views": {
      "git-jb": [
        {
          "type": "webview",
          "id": "git-jb.log",
          "name": "Log"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run build-webview && webpack",
    "watch": "webpack --watch",
    "package": "npm run build-webview && webpack --mode production --devtool hidden-source-map",
    "build-webview": "vite build",
    "watch-webview": "vite build --watch",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.80.0",
    "@vitejs/plugin-react": "^6.0.2",
    "ts-loader": "^9.4.4",
    "typescript": "^5.1.6",
    "vite": "^8.0.16",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "simple-git": "^3.36.0"
  }
}
